        st.slider("حدد مستوى الألم من 1 إلى 10:", 1, 10, 5)

elif menu == "2️⃣ الفحص الذاتي الموجه":
    st.subheader("📱 اختبارات منزلية استرشادية")
    st.warning("⚠️ تنبيه: هذه الاختبارات لا تغني عن الفحص السريري.")
    st.info("📋 الاختبار المقترح: اختبار القرفصاء الجزئي (Squat Test)")
    st.image("https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=500", caption="طبق التمرين وتوقف فوراً إذا زاد الألم")
    st.radio("ماذا شعرت أثناء أداء الاختبار؟", ["أديت الاختبار بنجاح وبدون ألم", "ظهر ألم شديد في صابونة الركبة", "شعور بعدم التوازن"])

elif menu == "3️⃣ خطتك العلاجية المخصصة":
    st.subheader("🏋️‍♂️ برنامج التأهيل الحركي الرقمي")
    st.error("🚨 التشخيص الأولي المستهدف: إجهاد في أوتار الركبة (Patellar Tendinopathy).")
    tab1, tab2 = st.tabs(["🎯 تمارين اليوم", "💡 نصائح يومية"])
    with tab1: st.markdown("* **انقباض ثابت للفخذ:** 3 مجموعات × 10 تكرارات.\n* **رفع الساق مستقيمة:** 3 مجموعات × 12 تكرار.")
    with tab2: st.markdown("* وضع كمادات باردة لمدة 12 دقيقة عند اشتداد الألم.\n* تجنب وضعيات ثني الركبة الحادة.")

elif menu == "4️⃣ برنامج التغذية والاستشفاء":
    st.subheader("🥗 التغذية العلاجية ومضادات الالتهاب")
    st.success("🎯 الهدف الحالي: تقليل التهاب الأنسجة وتسريع الاستشفاء.")
    st.markdown("- **مصادر الأوميغا 3:** السلمون، التونة، المكسرات.\n- **محفزات الاستشفاء:** الكركم، الزنجبيل splinter، التوت الأزرق.")
    st.metric(label="💧 مستهدف شرب الماء اليومي", value="3.5 لتر")

elif menu == "5️⃣ لوحة تحكم د. فريحان":
    st.subheader("👨‍⚕️ مراقبة تطور حالة المرضى (للأخصائي)")
    st.write("**📈 منحنى انخفاض الألم للمريض (أحمد) هذا الأسبوع:**")
    st.line_chart([8, 7, 6, 5, 5, 4, 3])
    st.progress(88)
    st.caption("المريض ملتزم بنسبة 88% بالبرنامج العلاجي.")

