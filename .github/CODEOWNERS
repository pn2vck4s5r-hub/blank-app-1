# قائمة التنقل للجوال
menu = st.selectbox(
    "📱 انتقل بين أقسام التطبيق التجريبي:",
    ["1️⃣ التحليل الذكي للألم", "2️⃣ الفحص الذاتي الموجه", "3️⃣ خطتك العلاجية المخصصة", "4️⃣ برنامج التغذية والاستشفاء", "5️⃣ لوحة تحكم د. فريحان"]
)

if menu == "1️⃣ التحليل الذكي للألم":
    st.subheader("📝 صف الألم أو الإصابة بلغتك الطبيعية:")
    user_input = st.text_area(label="اكتب هنا ما تشعر به:", value="أعاني من ألم في الركبة اليمنى منذ أسبوعين بعد لعب كرة القدم، ويزداد عند صعود الدرج.")
    if st.button("تحليل الإصابة بالذكاء الاصطناعي 🧠"):
        with st.spinner("جاري استخراج البيانات الكلينيكية..."): time.sleep(1.5)
        st.success("✅ تم تحليل النص بنجاح!")
        st.info("📍 **المفصل:** الركبة اليمنى | 🗓️ **المدة:** 14 يوماً | ⚡ **المحفز:** صعود الدرج")
